// Prisma schema para Reservas App — Barbería
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USUARIOS (dueños / staff de la barbería) =====
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hash bcrypt
  nombre    String
  rol       Role     @default(STAFF)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  bookings           Booking[]
  calendarConnections CalendarConnection[]

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// ===== CLIENTES (quienes reservan) =====
model Customer {
  id        String   @id @default(cuid())
  nombre    String
  apellidos String?
  telefono  String?
  email     String?
  notas     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  bookings Booking[]

  @@map("customers")
}

// ===== SERVICIOS (tipos de cita) =====
model Service {
  id          String  @id @default(cuid())
  nombre      String               // "Corte", "Barba", "Corte + Barba"
  duracion    Int                   // minutos
  precio      Float                // euros
  buffer      Int     @default(0)  // minutos de margen entre citas
  color       String  @default("#e94560") // color en el calendario
  activo      Boolean @default(true)
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  bookings Booking[]

  @@map("services")
}

// ===== REGLAS DE DISPONIBILIDAD =====
// Define el horario del negocio por día de la semana
model AvailabilityRule {
  id        String   @id @default(cuid())
  diaSemana Int      // 0=domingo, 1=lunes ... 6=sábado
  horaInicio String  // "09:00"
  horaFin    String  // "20:00"
  activo    Boolean  @default(true)
  userId    String?  @map("user_id") // null = horario global del negocio

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("availability_rules")
}

// ===== RESERVAS =====
model Booking {
  id         String        @id @default(cuid())
  fecha      DateTime      // fecha + hora de inicio
  fechaFin   DateTime      @map("fecha_fin") // fecha + hora de fin (calculada)
  estado     BookingStatus @default(CONFIRMADA)
  notas      String?

  // Relaciones
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  serviceId  String   @map("service_id")
  service    Service  @relation(fields: [serviceId], references: [id])

  userId     String?  @map("user_id") // barbero asignado
  user       User?    @relation(fields: [userId], references: [id])

  // Google Calendar
  googleEventId String? @map("google_event_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  reminders Reminder[]

  @@map("bookings")
}

enum BookingStatus {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
  NO_SHOW
}

// ===== CONEXIONES GOOGLE CALENDAR =====
model CalendarConnection {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  user         User    @relation(fields: [userId], references: [id])
  accessToken  String  @map("access_token")
  refreshToken String  @map("refresh_token")
  calendarId   String  @default("primary") @map("calendar_id")
  activo       Boolean @default(true)

  // Webhook push notifications
  syncToken     String?   @map("sync_token")
  channelId     String?   @map("channel_id")
  resourceId    String?   @map("resource_id")
  channelExpiry DateTime? @map("channel_expiry")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("calendar_connections")
}

// ===== RECORDATORIOS =====
model Reminder {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  booking   Booking      @relation(fields: [bookingId], references: [id])
  tipo      ReminderType
  canal     ReminderChannel
  enviarEn  DateTime     @map("enviar_en") // cuándo disparar
  enviado   Boolean  @default(false)
  enviadoAt DateTime? @map("enviado_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reminders")
}

enum ReminderType {
  CONFIRMACION
  RECORDATORIO_24H
  RECORDATORIO_1H
}

enum ReminderChannel {
  EMAIL
  WHATSAPP
  SMS
}
